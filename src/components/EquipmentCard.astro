---
// TYO Sound — EquipmentCard
// Bordered category card from the Equipment page. Values below are pulled
// directly from the live site's real "equipment__block" / "equipment__block-
// title" / "equipment__block-text" styles via the Webflow Data API (not
// estimated) — the design handoff's stated "square corners, 0 radius" rule
// didn't match: the real cards use a 20px radius. CMS-driven on the live
// site — this reads from src/data/equipment.json (the file the client/
// admin-UI edits).
interface Item { name: string; price: number; qty?: number }
interface Props {
  category: string;
  items: Item[];
}
const { category, items } = Astro.props;
---

<section class="card">
  <h3 class="heading">{category}</h3>
  <dl class="list">
    {items.map((it) => (
      <div class="row">
        <dt class="name">
          {it.name}
          {it.qty && it.qty > 1 ? <span class="qty">[{it.qty}X]</span> : null}
        </dt>
        <dd class="price">${it.price}/Day</dd>
      </div>
    ))}
  </dl>
</section>

<style>
  .card {
    border: var(--border-rule) solid var(--black);
    border-radius: 20px;
    background: var(--white);
    padding: 15px 20px;
    font-family: var(--font-sans);
    color: var(--black);
  }
  /* Real: font-size 2.9rem / 1.9rem (medium) / 1.5rem (tiny), line-height
     matching, letter-spacing -0.1rem, margin-bottom 40px. */
  .heading {
    margin: 0 0 40px;
    font-size: 2.9rem;
    line-height: 2.9rem;
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: -0.1rem;
  }
  @media (max-width: 991px) {
    .heading { font-size: 1.9rem; line-height: 1.9rem; }
  }
  @media (max-width: 479px) {
    .heading { font-size: 1.5rem; line-height: 1.5rem; }
  }
  .list { margin: 0; display: flex; flex-direction: column; }
  .row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-3) 0;
    border-top: 1px solid var(--border);
  }
  .row:first-child { border-top: none; }
  /* Real: name and price share the same "equipment__block-text" style —
     1.3rem, weight 500, uppercase — not two different smaller sizes. */
  .name {
    font-size: 1.3rem;
    line-height: 1.3rem;
    font-weight: 500;
    text-transform: uppercase;
    margin: 0;
  }
  .qty { color: var(--text-muted); font-weight: var(--weight-medium); margin-left: 8px; font-variant-numeric: tabular-nums; }
  .price {
    margin: 0;
    flex: none;
    font-size: 1.3rem;
    line-height: 1.3rem;
    font-weight: 500;
    text-transform: uppercase;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
</style>
