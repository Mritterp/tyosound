---
// TYO Sound — SiteFooter ("Let's Chat")
// Black full-bleed shared footer. Left: heading + contact form. Right:
// wordmark + locations, phone, email, Instagram.
//
// FORM BACKEND: static GitHub Pages can't receive POSTed form data itself,
// so this posts to Formspree (free tier, no server to run/maintain). The
// endpoint below is a PLACEHOLDER — create a free form at https://formspree.io
// (using matt@tyosound.com) and replace FORMSPREE_ENDPOINT with the real
// "https://formspree.io/f/xxxxxxx" URL it gives you. Until then the form UI
// works but submissions won't be delivered anywhere.
import Icon from './Icon.astro';

const FORMSPREE_ENDPOINT = 'https://formspree.io/f/REPLACE_ME';

interface Props {
  phone?: string;
  email?: string;
  locations?: string;
}
const {
  phone = '240.608.8286',
  email = 'matt@tyosound.com',
  locations = 'Washington, D.C. + Baltimore, MD',
} = Astro.props;
---

<footer class="footer" id="contact">
  <div class="grid">
    <div>
      <h2 class="heading">Let's Chat</h2>
      <form class="form" data-contact-form action={FORMSPREE_ENDPOINT} method="POST">
        <div class="fields-row">
          <label class="field">
            <span class="field-label">Name *</span>
            <input type="text" name="name" required />
          </label>
          <label class="field">
            <span class="field-label">Email Address *</span>
            <input type="email" name="email" required />
          </label>
        </div>
        <label class="field">
          <span class="field-label">Message</span>
          <textarea name="message" rows="3"></textarea>
        </label>
        <button type="submit" class="send-btn" data-send-btn>Send</button>
        <p class="form-status" data-form-status role="status" aria-live="polite"></p>
      </form>
    </div>

    <div class="details">
      <span class="wordmark">TYO Sound</span>
      <div class="detail-row">
        <Icon name="map-pin" size={18} /><span>{locations}</span>
      </div>
      <a href={`tel:${phone}`} class="detail-row link">
        <Icon name="phone" size={18} />{phone}
      </a>
      <a href={`mailto:${email}`} class="detail-row link">
        <Icon name="mail" size={18} />{email}
      </a>
      <a href="#" aria-label="Instagram" class="ig-link"><Icon name="instagram" size={22} /></a>
    </div>
  </div>
</footer>

<script>
  document.querySelectorAll<HTMLFormElement>('[data-contact-form]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector<HTMLButtonElement>('[data-send-btn]');
      const status = form.querySelector<HTMLElement>('[data-form-status]');
      if (!btn) return;
      const endpointIsPlaceholder = form.action.includes('REPLACE_ME');
      if (endpointIsPlaceholder) {
        if (status) status.textContent = 'Form backend not yet configured — see SiteFooter.astro.';
        return;
      }
      btn.disabled = true;
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          btn.textContent = 'Sent — thank you';
          btn.setAttribute('data-sent', 'true');
          form.reset();
        } else {
          if (status) status.textContent = 'Something went wrong — try again, or email us directly.';
          btn.disabled = false;
        }
      } catch {
        if (status) status.textContent = 'Something went wrong — try again, or email us directly.';
        btn.disabled = false;
      }
    });
  });
</script>

<style>
  .footer {
    background: var(--black);
    color: var(--white);
    padding: var(--section-pad-y) var(--page-gutter);
    font-family: var(--font-sans);
  }
  .grid {
    max-width: var(--content-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(0, 1fr);
    gap: var(--space-9);
    align-items: start;
  }
  .heading {
    font-size: var(--text-h1);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-6);
  }
  .form { display: flex; flex-direction: column; gap: var(--space-5); max-width: 520px; }
  .fields-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); }
  .field { display: block; }
  .field-label {
    display: block;
    font-size: var(--text-eyebrow);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 6px;
  }
  .field input,
  .field textarea {
    width: 100%;
    box-sizing: border-box;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--border-inverse);
    color: var(--white);
    font-family: var(--font-sans);
    font-size: var(--text-body);
    padding: 10px 0;
    outline: none;
  }
  .field textarea { resize: vertical; }
  .field input:focus,
  .field textarea:focus { border-bottom-color: var(--white); }

  .send-btn {
    align-self: flex-start;
    font-family: var(--font-sans);
    font-weight: var(--weight-medium);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 13px 30px;
    border-radius: var(--radius-md);
    border: var(--border-rule) solid var(--white);
    background: var(--white);
    color: var(--black);
    cursor: pointer;
  }
  .send-btn[data-sent='true'] { background: transparent; color: var(--white); }
  .send-btn:disabled { cursor: default; opacity: 0.7; }
  .form-status { font-size: var(--text-sm); color: var(--gray-400); margin: 0; min-height: 1em; }

  .details { display: flex; flex-direction: column; gap: var(--space-5); padding-top: var(--space-2); }
  .wordmark { font-weight: var(--weight-bold); letter-spacing: 0.14em; font-size: 20px; text-transform: uppercase; }
  .detail-row { display: flex; align-items: center; gap: 10px; color: rgba(255, 255, 255, 0.85); font-size: var(--text-body); }
  .detail-row.link { color: var(--white); text-decoration: none; transition: opacity var(--dur-fast); }
  .detail-row.link:hover { opacity: var(--hover-opacity); }
  .ig-link { color: var(--white); margin-top: var(--space-2); width: max-content; transition: opacity var(--dur-fast); }
  .ig-link:hover { opacity: var(--hover-opacity); }

  @media (max-width: 760px) {
    .grid { grid-template-columns: 1fr; gap: var(--space-7); }
    .fields-row { grid-template-columns: 1fr; }
  }
</style>
