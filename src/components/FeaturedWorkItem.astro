---
// TYO Sound — FeaturedWorkItem
// A Featured Work row: oversized Light-300 uppercase title + client label.
// Clicking toggles it open (video mounts) — single-open + service-filter
// state is coordinated by the page-level script via data-cat / data-open.
import Icon from './Icon.astro';

interface Props {
  id: string;
  title: string;
  client: string;
  role?: string;
  cat: string;
  youtubeId?: string;
  open?: boolean;
}
const { id, title, client, role, cat, youtubeId, open = false } = Astro.props;
---

<div class="row" data-work-item data-id={id} data-cat={cat} data-open={open}>
  <button class="row-head" data-work-toggle aria-expanded={open}>
    <span class="text">
      <span class="title-row">
        <span class="title">{title}</span>
        <span class="hoverwave" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></span>
      </span>
      <span class="meta">{client}{role ? ` — ${role}` : ''}</span>
    </span>
    <span class="play-btn">
      <Icon name="minus" size={20} class="icon-minus" />
      <Icon name="play" size={15} class="icon-play" />
    </span>
  </button>

  <div class="expand">
    <div class="expand-inner">
      <div class="media">
        {youtubeId && (
          <iframe
            title={title}
            data-youtube-src={`https://www.youtube-nocookie.com/embed/${youtubeId}`}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        )}
      </div>
    </div>
  </div>
</div>

<style>
  .row { border-top: 1px solid var(--border); }
  .row-head {
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
    color: var(--black);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    padding: var(--space-5) 0;
    text-align: left;
  }
  .text { display: flex; flex-direction: column; gap: 6px; opacity: 0.9; transition: opacity var(--dur-base); }
  .row-head:hover .text { opacity: 1; }
  .title-row { display: flex; align-items: center; }
  /* Real values pulled from the live Webflow site's "featuredwork-title"
     style/breakpoints via the Data API (not estimated from screenshots):
     base 5.7rem/-0.3rem tracking, stepping down at their exact breakpoints. */
  .title {
    font-size: 5.7rem;
    line-height: 5.7rem;
    font-weight: var(--weight-light);
    text-transform: uppercase;
    letter-spacing: -0.3rem;
    transition: font-weight var(--dur-base), transform var(--dur-base) var(--ease-out), color var(--dur-base);
    display: block;
  }
  @media (max-width: 991px) {
    .title { font-size: 3.3rem; line-height: 3.3rem; }
  }
  @media (max-width: 767px) {
    .title { font-size: 2.5rem; line-height: 2.5rem; letter-spacing: -0.15rem; }
  }
  @media (max-width: 479px) {
    .title { font-size: 1.8rem; line-height: 1.8rem; }
  }
  .row[data-open='true'] .title { font-weight: var(--weight-regular); }
  .row-head:hover .title { transform: translateX(8px); }
  .row[data-open='true'] .row-head:hover .title { transform: none; }
  /* Hover color/weight is a confirmed real deviation from the "monochrome,
     no accent hue" brand rule stated elsewhere in the design handoff — this
     exact hover pseudo (color + weight) is pulled directly from the live
     site's CSS, not invented, so it wins over that stated rule here. */
  .row-head:hover .title { color: #245486; font-weight: var(--weight-bold); }

  .hoverwave {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    height: 28px;
    margin-left: var(--space-5);
    color: #245486;
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity var(--dur-base) var(--ease-out), transform var(--dur-base) var(--ease-out);
  }
  .hoverwave i { display: block; width: 4px; border-radius: 2px; background: currentColor; }
  .hoverwave i:nth-child(1) { height: 30%; }
  .hoverwave i:nth-child(2) { height: 65%; }
  .hoverwave i:nth-child(3) { height: 100%; }
  .hoverwave i:nth-child(4) { height: 50%; }
  .hoverwave i:nth-child(5) { height: 75%; }
  .row-head:hover .hoverwave { opacity: 1; transform: translateX(0); }
  .row-head:hover .hoverwave i { animation: hoverwave-bounce 0.9s var(--ease-standard) infinite; }
  .hoverwave i:nth-child(2) { animation-delay: 0.08s; }
  .hoverwave i:nth-child(3) { animation-delay: 0.16s; }
  .hoverwave i:nth-child(4) { animation-delay: 0.24s; }
  .hoverwave i:nth-child(5) { animation-delay: 0.32s; }
  @keyframes hoverwave-bounce {
    0%, 100% { transform: scaleY(1); }
    50% { transform: scaleY(0.45); }
  }
  @media (prefers-reduced-motion: reduce) {
    .row-head:hover .hoverwave i { animation: none; }
  }

  .meta {
    font-size: var(--text-eyebrow);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .play-btn {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-pill);
    border: 2px solid var(--black);
    background: transparent;
    color: var(--black);
    transition: all var(--dur-base) var(--ease-standard);
  }
  .icon-minus { display: none; }
  .row[data-open='true'] .play-btn { background: var(--black); color: var(--white); }
  .row[data-open='true'] .icon-play { display: none; }
  .row[data-open='true'] .icon-minus { display: block; }

  .expand {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--dur-slow) var(--ease-out);
  }
  .row[data-open='true'] .expand { grid-template-rows: 1fr; }
  .expand-inner { overflow: hidden; }
  .media {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--black);
    border-radius: var(--radius-sm);
    overflow: hidden;
    margin-bottom: var(--space-6);
  }
  .media iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: none; }

  /* filtered-out rows (different service category) are hidden entirely */
  .row[data-hidden='true'] { display: none; }
</style>
