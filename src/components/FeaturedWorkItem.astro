---
// TYO Sound — FeaturedWorkItem
// A Featured Work row: oversized Light-300 uppercase title + client label.
// Clicking toggles it open (video mounts) — single-open + service-filter
// state is coordinated by the page-level script via data-cat / data-open.
interface Props {
  id: string;
  title: string;
  client: string;
  role?: string;
  cat: string;
  youtubeId?: string;
  startSeconds?: number; // optional YouTube start-time offset
  // image carousel — alternative media type to youtubeId. A plain string
  // uses the gallery-wide `credit` fallback; an object can override it
  // per-slide (credit: null explicitly suppresses the fallback, e.g. for
  // a design render mixed in with real credited photos).
  images?: (string | { src: string; credit?: string | null })[];
  credit?: string; // fallback photo credit line for slides that don't override it
  imageFit?: 'cover' | 'contain'; // 'contain' letterboxes portrait/odd-aspect images with a blurred backdrop instead of cropping
  open?: boolean;
}
const { id, title, client, role, cat, youtubeId, startSeconds, images, credit, imageFit = 'cover', open = false } = Astro.props;
const youtubeSrc = youtubeId
  ? `https://www.youtube-nocookie.com/embed/${youtubeId}${startSeconds ? `?start=${startSeconds}` : ''}`
  : undefined;
const slides = images?.map((img) => {
  if (typeof img === 'string') return { src: img, credit: credit || '' };
  const c = img.credit === null ? '' : (img.credit ?? credit ?? '');
  return { src: img.src, credit: c };
});
---

<div class="row" data-work-item data-id={id} data-cat={cat} data-open={open}>
  <button class="row-head" data-work-toggle aria-expanded={open}>
    <span class="text">
      <span class="title-row">
        <span class="title">{title}</span>
        <span class="hoverwave" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i><i></i><i></i></span>
      </span>
      <span class="meta">{client}{role ? ` — ${role}` : ''}</span>
    </span>
  </button>

  <div class="expand">
    <div class="media">
      {youtubeId && (
        <iframe
          title={title}
          data-youtube-src={youtubeSrc}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      )}
      {slides && slides.length > 0 && (
        <div class="carousel" data-carousel data-fit={imageFit}>
          {slides.map((slide, i) => (
            <div class="carousel-frame" data-carousel-slide data-active={i === 0 ? 'true' : undefined} data-credit={slide.credit}>
              {imageFit === 'contain' && <img src={slide.src} alt="" aria-hidden="true" class="carousel-bloom" loading="lazy" />}
              <img src={slide.src} alt={title} class="carousel-img" loading="lazy" />
            </div>
          ))}
          {slides.length > 1 && (
            <>
              <button class="carousel-nav carousel-prev" data-carousel-prev type="button" aria-label="Previous image">‹</button>
              <button class="carousel-nav carousel-next" data-carousel-next type="button" aria-label="Next image">›</button>
              <div class="carousel-dots">
                {slides.map((_, i) => <span class="dot" data-dot data-active={i === 0 ? 'true' : undefined} role="button" tabindex="0" aria-label={`Go to image ${i + 1}`}></span>)}
              </div>
            </>
          )}
          <span class="carousel-credit" data-carousel-credit>{slides[0]?.credit}</span>
        </div>
      )}
    </div>
  </div>
</div>

<script>
  // Image carousels (Astro dedupes this script once across every
  // FeaturedWorkItem instance, so it wires up all of them after render).
  document.querySelectorAll('[data-carousel]').forEach((carousel) => {
    const slides = [...carousel.querySelectorAll('[data-carousel-slide]')];
    const dots = [...carousel.querySelectorAll('[data-dot]')];
    const prevBtn = carousel.querySelector('[data-carousel-prev]');
    const nextBtn = carousel.querySelector('[data-carousel-next]');
    const creditEl = carousel.querySelector('[data-carousel-credit]');
    let index = 0;
    function show(i) {
      index = (i + slides.length) % slides.length;
      slides.forEach((s, si) => s.toggleAttribute('data-active', si === index));
      dots.forEach((d, di) => d.toggleAttribute('data-active', di === index));
      if (creditEl) {
        const text = slides[index]?.dataset.credit || '';
        creditEl.textContent = text;
        creditEl.style.display = text ? '' : 'none';
      }
    }
    prevBtn?.addEventListener('click', (e) => { e.preventDefault(); show(index - 1); });
    nextBtn?.addEventListener('click', (e) => { e.preventDefault(); show(index + 1); });
    dots.forEach((d, di) => d.addEventListener('click', () => show(di)));
    show(0);
  });
</script>

<style>
  .row-head {
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
    color: var(--black);
    display: flex;
    align-items: center;
    padding: var(--space-5) 0;
    text-align: left;
  }
  .text { display: flex; flex-direction: column; gap: 6px; opacity: 0.9; transition: opacity var(--dur-base); }
  .row-head:hover .text { opacity: 1; }
  .title-row { display: flex; align-items: center; }
  /* Real values pulled from the live Webflow site's "featuredwork-title"
     style/breakpoints via the Data API (not estimated from screenshots):
     base 5.7rem/-0.3rem tracking, stepping down at their exact breakpoints. */
  .title {
    font-size: 5.7rem;
    line-height: 5.7rem;
    font-weight: var(--weight-light);
    text-transform: uppercase;
    letter-spacing: -0.3rem;
    transition: font-weight var(--dur-base), transform var(--dur-base) var(--ease-out), color var(--dur-base);
    display: block;
  }
  @media (max-width: 991px) {
    .title { font-size: 3.3rem; line-height: 3.3rem; }
  }
  @media (max-width: 767px) {
    .title { font-size: 2.5rem; line-height: 2.5rem; letter-spacing: -0.15rem; }
  }
  @media (max-width: 479px) {
    .title { font-size: 1.8rem; line-height: 1.8rem; }
  }
  .row[data-open='true'] .title { font-weight: var(--weight-regular); }
  .row-head:hover .title { transform: translateX(8px); }
  .row[data-open='true'] .row-head:hover .title { transform: none; }
  /* Hover color/weight is a confirmed real deviation from the "monochrome,
     no accent hue" brand rule stated elsewhere in the design handoff — this
     exact hover pseudo (color + weight) is pulled directly from the live
     site's CSS, not invented, so it wins over that stated rule here. */
  .row-head:hover .title { color: #245486; font-weight: var(--weight-bold); }

  /* Sized relative to the title so it scales down at the same breakpoints
     — matched to the screenshot: taller relative to the text than the
     first pass, 7 bars (not 5), rounded (pill) ends. */
  .hoverwave {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    height: 54px;
    margin-left: var(--space-5);
    color: #245486;
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity var(--dur-base) var(--ease-out), transform var(--dur-base) var(--ease-out);
  }
  @media (max-width: 991px) { .hoverwave { height: 32px; } }
  @media (max-width: 767px) { .hoverwave { height: 24px; } }
  @media (max-width: 479px) { .hoverwave { height: 17px; } }
  /* Rounded (pill) ends, matching the original — each bar runs its OWN
     keyframes/duration/delay so they bounce independently rather than as
     one synchronized ripple. */
  .hoverwave i { display: block; width: 4px; border-radius: 999px; background: currentColor; transform-origin: center; }
  .hoverwave i:nth-child(1) { height: 40%; }
  .hoverwave i:nth-child(2) { height: 65%; }
  .hoverwave i:nth-child(3) { height: 85%; }
  .hoverwave i:nth-child(4) { height: 100%; }
  .hoverwave i:nth-child(5) { height: 80%; }
  .hoverwave i:nth-child(6) { height: 55%; }
  .hoverwave i:nth-child(7) { height: 35%; }
  .row-head:hover .hoverwave { opacity: 1; transform: translateX(0); }
  .row-head:hover .hoverwave i:nth-child(1) { animation: wave-a 0.62s ease-in-out infinite; }
  .row-head:hover .hoverwave i:nth-child(2) { animation: wave-b 0.83s ease-in-out infinite; }
  .row-head:hover .hoverwave i:nth-child(3) { animation: wave-c 0.71s ease-in-out infinite; }
  .row-head:hover .hoverwave i:nth-child(4) { animation: wave-d 0.95s ease-in-out infinite; }
  .row-head:hover .hoverwave i:nth-child(5) { animation: wave-e 0.68s ease-in-out infinite; }
  .row-head:hover .hoverwave i:nth-child(6) { animation: wave-b 0.77s ease-in-out infinite; }
  .row-head:hover .hoverwave i:nth-child(7) { animation: wave-c 0.9s ease-in-out infinite; }
  @keyframes wave-a { 0%, 100% { transform: scaleY(1); } 40% { transform: scaleY(0.35); } 70% { transform: scaleY(0.8); } }
  @keyframes wave-b { 0%, 100% { transform: scaleY(0.5); } 30% { transform: scaleY(1); } 65% { transform: scaleY(0.25); } }
  @keyframes wave-c { 0%, 100% { transform: scaleY(0.8); } 50% { transform: scaleY(0.3); } 80% { transform: scaleY(1); } }
  @keyframes wave-d { 0%, 100% { transform: scaleY(0.4); } 35% { transform: scaleY(0.9); } 75% { transform: scaleY(0.55); } }
  @keyframes wave-e { 0%, 100% { transform: scaleY(1); } 45% { transform: scaleY(0.5); } 85% { transform: scaleY(0.75); } }
  @media (prefers-reduced-motion: reduce) {
    .row-head:hover .hoverwave i { animation: none; }
  }

  .meta {
    font-size: var(--text-eyebrow);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* Height is set to an explicit px value by JS (measured via scrollHeight)
     rather than the grid-template-rows: 0fr/1fr trick — that technique
     interpolates grid track sizing, which several browsers animate
     unevenly/janky. A plain height transition between two real pixel
     values is simple linear interpolation and renders far smoother. */
  .expand {
    height: 0;
    overflow: hidden;
    transition: height var(--dur-slow) var(--ease-out);
    will-change: height;
  }
  .media {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--black);
    border-radius: var(--radius-sm);
    overflow: hidden;
    margin-bottom: var(--space-6);
  }
  /* The box is sized by aspect-ratio immediately, independent of whether
     the YouTube iframe has actually loaded yet — so the expand animation
     is never blocked on network timing. The iframe itself fades in once
     ready (JS toggles opacity on 'load') instead of popping in abruptly
     mid-animation. */
  .media iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  /* Image carousel — same media box, an alternative to the video iframe. */
  .carousel { position: absolute; inset: 0; }
  .carousel-frame {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .carousel-frame[data-active='true'] { opacity: 1; }
  .carousel-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* imageFit="contain" — for portrait/odd-aspect sources (e.g. a vertical
     poster) that would otherwise be cropped by cover. The sharp image is
     letterboxed (contain), and a blurred, oversized copy of the same image
     fills the rest of the horizontal frame as a soft glow/bloom backdrop
     instead of plain black bars. */
  .carousel[data-fit='contain'] .carousel-img { object-fit: contain; }
  .carousel-bloom {
    position: absolute;
    inset: -10%;
    width: 120%;
    height: 120%;
    object-fit: cover;
    filter: blur(50px) saturate(1.6) brightness(1.1);
    transform: scale(1.15);
  }
  .carousel-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: rgba(0, 0, 0, 0.5);
    color: var(--white);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    line-height: 1;
    transition: background var(--dur-fast);
  }
  .carousel-nav:hover { background: rgba(0, 0, 0, 0.7); }
  .carousel-prev { left: 12px; }
  .carousel-next { right: 12px; }
  .carousel-dots {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
  }
  .dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(255, 255, 255, 0.5); cursor: pointer; }
  .dot[data-active='true'] { background: var(--white); }
  .carousel-credit {
    position: absolute;
    bottom: 8px;
    right: 12px;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.85);
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.8);
  }

  /* filtered-out rows (different service category) are hidden entirely */
  .row[data-hidden='true'] { display: none; }
</style>
