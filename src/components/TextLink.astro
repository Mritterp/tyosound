---
// TYO Sound — TextLink
// The site's signature inline link: uppercase link with a 2px underline
// rule. Used for "Check out our equipment", "Contact for availability", etc.
//
// Hover behavior and font-size/letter-spacing/padding are pulled directly
// from the live Webflow site's real "link-button" style (via the Data API,
// not guessed): on hover a white panel rises from the bottom to fill the
// link and the ink flips to black — a real fill-inversion, consistent with
// the design system's stated "never a hue change" hover rule.
interface Props {
  href?: string;
  onLight?: boolean;
  class?: string;
}
const { href = '#', onLight = true, class: className } = Astro.props;
---

<a href={href} class:list={['text-link', className]} data-on-light={onLight}>
  <span class="text-link-fill" aria-hidden="true"></span>
  <span class="text-link-label"><slot /></span>
</a>

<style>
  .text-link {
    position: relative;
    overflow: hidden;
    display: inline-block;
    width: max-content;
    font-family: var(--font-sans);
    font-weight: var(--weight-medium);
    font-size: 1.3rem;
    letter-spacing: 0;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--black);
    border-bottom: var(--border-rule) solid var(--black);
    padding: 5px 10px 3px;
  }
  .text-link[data-on-light='false'] {
    color: var(--white);
    border-bottom-color: var(--white);
  }
  .text-link-label {
    position: relative;
    z-index: 1;
    transition: color var(--dur-base) var(--ease-standard);
  }
  .text-link-fill {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: var(--white);
    transform: translateY(100%);
    transition: transform var(--dur-base) var(--ease-out);
  }
  .text-link:hover,
  .text-link:focus-visible {
    border-bottom-color: var(--black);
  }
  .text-link:hover .text-link-label,
  .text-link:focus-visible .text-link-label {
    color: var(--black);
  }
  .text-link:hover .text-link-fill,
  .text-link:focus-visible .text-link-fill {
    transform: translateY(0);
  }
  .text-link:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-offset);
  }
</style>
