---
// TYO Sound — TrustBar
// Client/network logo row. Real official marks, sourced from Wikimedia
// Commons (public-domain-status vector files, per each file's own page —
// still trademarked, used here the same "worked with" factual way the
// original site used them). Forced to solid monochrome via CSS filter
// since the brand has no color system, regardless of each logo's real
// intrinsic colors.
interface Client {
  name: string;
  src: string;
  // some marks (e.g. a near-square icon vs. a wide wordmark) read better
  // a bit larger/smaller at a shared row height — per-logo scale nudge.
  scale?: number;
  // Logos that are already genuinely two-tone (e.g. ABC's black circle +
  // white lowercase letters) need a plain color invert() to preserve that
  // internal contrast — brightness(0) invert(1) crushes both tones to the
  // same black first, erasing the letters entirely.
  bitonal?: boolean;
}
interface Props {
  clients?: Client[];
  onLight?: boolean;
  label?: string;
}
const base = import.meta.env.BASE_URL;
const {
  clients = [
    { name: 'NBC', src: `${base}/img/logos/nbc.svg` },
    { name: 'VICE', src: `${base}/img/logos/vice.svg` },
    { name: 'HBO', src: `${base}/img/logos/hbo.svg` },
    { name: 'ABC', src: `${base}/img/logos/abc.svg`, scale: 0.8, bitonal: true },
    { name: 'Netflix', src: `${base}/img/logos/netflix.svg`, scale: 1.1 },
    { name: 'CBS', src: `${base}/img/logos/cbs.svg` },
    { name: 'PBS', src: `${base}/img/logos/pbs.svg`, bitonal: true },
    { name: 'Kaiser Permanente', src: `${base}/img/logos/kaiser.svg`, scale: 1.3 },
    // Blue Cross Blue Shield: no clean national-logo SVG found on Wikimedia
    // Commons (only regional variants, e.g. Blue Shield of California) —
    // holding off rather than guessing which entity/mark is right. Add a
    // client entry here once a logo file is supplied.
  ],
  onLight = false,
  label,
} = Astro.props;
---

<div class="trust" data-on-light={onLight}>
  {label && <div class="label">{label}</div>}
  <div class="row">
    {clients.map((c) => (
      <img
        class="client-logo"
        data-bitonal={c.bitonal ? 'true' : undefined}
        src={c.src}
        alt={c.name}
        style={c.scale ? `--scale: ${c.scale}` : undefined}
      />
    ))}
  </div>
</div>

<style>
  .trust { font-family: var(--font-sans); }
  .label {
    font-size: var(--text-eyebrow);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: var(--space-5);
  }
  .trust[data-on-light='true'] .label { color: var(--text-muted); }
  .row { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-8); }
  .client-logo {
    --scale: 1;
    height: calc(26px * var(--scale));
    width: auto;
    opacity: 0.85;
    /* Forces pure white regardless of the source logo's real colors. */
    filter: brightness(0) invert(1);
  }
  .trust[data-on-light='true'] .client-logo {
    /* Forces pure black instead, for use on a light background. */
    filter: brightness(0);
  }
  /* Genuinely two-tone source logos: swap polarity instead of crushing to
     one color, so internal contrast (e.g. ABC's letters) survives. */
  .client-logo[data-bitonal='true'] {
    filter: invert(1);
  }
  .trust[data-on-light='true'] .client-logo[data-bitonal='true'] {
    filter: none;
  }
</style>
