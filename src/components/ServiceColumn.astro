---
// TYO Sound — ServiceColumn
// One column of the black "What we do" section. Selecting one filters the
// Featured Work list below (wired via data-cat + the page-level script).
//
// Structural note: the CTA link must NOT be nested inside the clickable
// <button> (a link inside a button is invalid HTML and breaks click
// handling) — so only idx/title/body are the button; the outer wrapper
// carries data-service-col/data-cat/data-selected for the page script,
// and TextLink sits as a sibling after the button.
import TextLink from './TextLink.astro';

interface Props {
  index: number;
  title: string;
  body: string;
  cat: string;
  selected?: boolean;
  linkLabel?: string;
  linkHref?: string;
}
const { index, title, body, cat, selected = false, linkLabel, linkHref } = Astro.props;
---

<div class="col" data-service-col data-cat={cat} data-selected={selected}>
  <button class="col-select" aria-pressed={selected}>
    <span class="idx">{String(index).padStart(2, '0')}</span>
    <span class="title">{title}</span>
    <span class="body">{body}</span>
    <span class="cue" aria-hidden="true"><span class="cue-text">See this work ↓</span></span>
  </button>
  {linkLabel && linkHref && (
    <TextLink href={linkHref} onLight={false} class="col-link">{linkLabel}</TextLink>
  )}
</div>

<style>
  .col {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5) 0;
    border-top: var(--border-rule) solid var(--border-inverse);
    opacity: 0.5;
    transition: opacity var(--dur-base) var(--ease-standard), border-color var(--dur-base);
    width: 100%;
  }
  .col[data-selected='true'] { opacity: 1; border-top-color: var(--white); }
  .col:hover { opacity: 0.85; }
  .col[data-selected='true']:hover { opacity: 1; }

  .col-select {
    text-align: left;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--white);
    font-family: var(--font-sans);
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    width: 100%;
  }

  .idx {
    font-size: var(--text-eyebrow);
    letter-spacing: var(--tracking-wider);
    color: rgba(255, 255, 255, 0.55);
    font-variant-numeric: tabular-nums;
  }
  .title {
    font-size: var(--text-h3);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--tracking-tight);
    line-height: 1.05;
  }
  .body {
    font-size: var(--text-body);
    font-weight: var(--weight-regular);
    line-height: var(--leading-normal);
    color: rgba(255, 255, 255, 0.78);
  }
  .col :global(.col-link) {
    margin-top: var(--space-2);
  }

  /* Hover-only "See this work" cue, from a Claude Design supplied snippet.
     Pure CSS: hovering a non-selected column reveals it and plays a
     one-shot chromatic-aberration glitch — no JS needed for the
     "replay every hover" behavior, since a :hover-scoped animation
     naturally restarts each time the hover state re-triggers. The red/
     cyan split colors are a deliberate accent, another confirmed
     exception to the brand's monochrome rule (same category as the
     Featured Work title's blue hover) — implemented as supplied. */
  .cue {
    margin-top: var(--space-1);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity var(--dur-base) var(--ease-standard), transform var(--dur-base) var(--ease-standard);
  }
  .col-select:hover .cue {
    opacity: 1;
    transform: translateY(0);
  }
  .col[data-selected='true'] .cue {
    display: none;
  }
  .cue-text {
    display: inline-block;
    transform-origin: center;
    will-change: transform, filter, letter-spacing;
  }
  .col-select:hover .cue-text {
    animation: tyoSvcCueGlitch 0.6s steps(1, end) 1 both;
  }
  @keyframes tyoSvcCueGlitch {
    0%   { letter-spacing: 0.16em;  transform: translateX(-2px); filter: brightness(1.4);
           text-shadow: -1.5px 0 rgba(255, 0, 70, .7), 1.5px 0 rgba(0, 240, 220, .7); }
    18%  { letter-spacing: -0.02em; transform: translateX(2px);  filter: brightness(1.08);
           text-shadow: 2px 0 rgba(255, 0, 70, .6), -2px 0 rgba(0, 240, 220, .6); }
    38%  { letter-spacing: 0.1em;   transform: translateX(-1px);
           text-shadow: -1px 0 rgba(255, 0, 70, .45), 1px 0 rgba(0, 240, 220, .45); }
    58%  { letter-spacing: 0.04em;  transform: none;
           text-shadow: 0.5px 0 rgba(255, 0, 70, .3), -0.5px 0 rgba(0, 240, 220, .3); }
    78%  { letter-spacing: 0.06em;  transform: none; text-shadow: none; filter: none; }
    100% { letter-spacing: 0.06em;  transform: none; text-shadow: none; filter: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .col-select:hover .cue-text { animation: none; }
  }
</style>
