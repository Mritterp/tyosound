---
// TYO Sound — ServiceColumn
// One column of the black "What we do" section. Selecting one filters the
// Featured Work list below (wired via data-cat + the page-level script).
//
// Structural note: the CTA link must NOT be nested inside the clickable
// <button> (a link inside a button is invalid HTML and breaks click
// handling) — so only idx/title/body are the button; the outer wrapper
// carries data-service-col/data-cat/data-selected for the page script,
// and TextLink sits as a sibling after the button.
import TextLink from './TextLink.astro';

interface Props {
  index: number;
  title: string;
  body: string;
  cat: string;
  selected?: boolean;
  linkLabel?: string;
  linkHref?: string;
}
const { index, title, body, cat, selected = false, linkLabel, linkHref } = Astro.props;
---

<div class="col" data-service-col data-cat={cat} data-selected={selected}>
  <button class="col-select" aria-pressed={selected}>
    <span class="idx">{String(index).padStart(2, '0')}</span>
    <span class="title">{title}</span>
    <span class="body">{body}</span>
  </button>
  {linkLabel && linkHref && (
    <TextLink href={linkHref} onLight={false} class="col-link">{linkLabel}</TextLink>
  )}
</div>

<style>
  .col {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5) 0;
    border-top: var(--border-rule) solid var(--border-inverse);
    opacity: 0.5;
    transition: opacity var(--dur-base) var(--ease-standard), border-color var(--dur-base);
    width: 100%;
  }
  .col[data-selected='true'] { opacity: 1; border-top-color: var(--white); }
  .col:hover { opacity: 0.85; }
  .col[data-selected='true']:hover { opacity: 1; }

  .col-select {
    text-align: left;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--white);
    font-family: var(--font-sans);
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    width: 100%;
  }

  .idx {
    font-size: var(--text-eyebrow);
    letter-spacing: var(--tracking-wider);
    color: rgba(255, 255, 255, 0.55);
    font-variant-numeric: tabular-nums;
  }
  .title {
    font-size: var(--text-h3);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--tracking-tight);
    line-height: 1.05;
  }
  .body {
    font-size: var(--text-body);
    font-weight: var(--weight-regular);
    line-height: var(--leading-normal);
    color: rgba(255, 255, 255, 0.78);
  }
  .col :global(.col-link) {
    margin-top: var(--space-2);
  }
</style>
