---
import '../styles/styles.css';
import NavHeader from '../components/NavHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import TextLink from '../components/TextLink.astro';
import EquipmentCard from '../components/EquipmentCard.astro';
import SEOHead from '../components/SEOHead.astro';
import equipmentData from '../data/equipment.json';

const base = import.meta.env.BASE_URL;
const categories = [...equipmentData.categories].sort((a, b) => a.sortingOrder - b.sortingOrder);
// Split into two independent columns (alternating) rather than a single
// CSS grid — a grid auto-places these into shared rows, so a short card
// on one side gets stretched to match its taller row-mate on the other,
// leaving a gap before the next card in its own column. Two separate
// flex columns let each side stack tightly regardless of the other.
const leftCol = categories.filter((_, i) => i % 2 === 0);
const rightCol = categories.filter((_, i) => i % 2 === 1);
const description = 'Professional audio equipment for rent from TYO Sound — mixers, recorders, microphones, wireless, timecode, and sound reinforcement. Washington, D.C. and Baltimore.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEOHead title="Equipment Rental — TYO Sound" description={description} ogImage={`${base}/img/equipment-action.jpg`} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <NavHeader theme="light" active="Equipment" />

    <main id="main">
    <section class="eq-hero">
      <div class="content eq-hero-grid">
        <div class="eq-hero-text">
          <h1 class="eq-title">Equipment<br />Rental</h1>
          <p class="eq-sub">From live events to run and gun docs, we've got you covered.</p>
          <TextLink href="#contact">Contact for availability</TextLink>
        </div>
        <div class="eq-hero-photo">
          <img src={`${base}/img/equipment-action.jpg`} alt="Sound mixer wearing a production sound bag rig" />
        </div>
      </div>
    </section>

    <section class="eq-grid-section">
      <div class="content">
        <div class="eq-grid">
          <div class="eq-col eq-col-desktop">
            {leftCol.map((cat) => (
              <EquipmentCard category={cat.name} items={cat.items} />
            ))}
          </div>
          <div class="eq-col eq-col-desktop">
            {rightCol.map((cat) => (
              <EquipmentCard category={cat.name} items={cat.items} />
            ))}
          </div>
          {/* Separate, hidden-until-mobile column in full sortingOrder --
              the two columns above are split by alternating index to get
              the independent-stacking layout on desktop, which would
              scramble the reading order (left column fully, then right
              column fully) if just stacked on narrow screens instead. */}
          <div class="eq-col eq-col-mobile">
            {categories.map((cat) => (
              <EquipmentCard category={cat.name} items={cat.items} />
            ))}
          </div>
        </div>
      </div>
    </section>
    </main>

    <SiteFooter />

    <style>
      /* "Contact for availability" now anchors to this page's own footer
         (was a cross-page link to the home page's #contact) — smooth
         scroll matches the home page's behavior. */
      :global(html) { scroll-behavior: smooth; }
      @media (prefers-reduced-motion: reduce) {
        :global(html) { scroll-behavior: auto; }
      }
      body { margin: 0; font-family: var(--font-sans); background: var(--bg-page); }
      .content { max-width: var(--content-max); margin: 0 auto; padding: 0 var(--page-gutter); }

      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        z-index: 100;
        background: var(--white);
        color: var(--black);
        padding: var(--space-3) var(--space-5);
        font-family: var(--font-sans);
        font-weight: var(--weight-medium);
        text-transform: uppercase;
        letter-spacing: var(--tracking-wide);
      }
      .skip-link:focus {
        left: var(--space-4);
        top: var(--space-4);
      }

      .eq-hero { padding: var(--space-8) 0 var(--section-pad-y); }
      .eq-hero-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: var(--space-8); align-items: center; }
      .eq-title {
        margin: var(--space-3) 0 var(--space-5);
        font-weight: var(--weight-bold);
        text-transform: uppercase;
        font-size: var(--text-display);
        line-height: var(--leading-tight);
      }
      .eq-sub { max-width: 46ch; font-size: var(--text-lg); font-weight: var(--weight-regular); color: var(--gray-600); margin: 0 0 var(--space-6); }
      .eq-hero-photo { aspect-ratio: 4 / 5; overflow: hidden; }
      .eq-hero-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }

      .eq-grid-section { padding-bottom: var(--section-pad-y); }
      .eq-grid { display: flex; gap: var(--space-6); align-items: flex-start; }
      .eq-col { display: flex; flex-direction: column; gap: var(--space-6); flex: 1; min-width: 0; }
      .eq-col-mobile { display: none; }

      @media (max-width: 760px) {
        .eq-hero-grid { grid-template-columns: 1fr; }
        .eq-hero-photo { order: -1; aspect-ratio: 16 / 10; }
        .eq-grid { flex-direction: column; }
        .eq-col-desktop { display: none; }
        .eq-col-mobile { display: flex; }
      }
    </style>
  </body>
</html>
