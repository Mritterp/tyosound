---
import '../styles/styles.css';
import NavHeader from '../components/NavHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';
import TextLink from '../components/TextLink.astro';
import ServiceColumn from '../components/ServiceColumn.astro';
import TrustBar from '../components/TrustBar.astro';
import FeaturedWorkItem from '../components/FeaturedWorkItem.astro';
import SEOHead from '../components/SEOHead.astro';
import projectsData from '../data/projects.json';
import instagramData from '../data/instagram.json';

const base = import.meta.env.BASE_URL;
const projects = projectsData.projects;

const services = [
  {
    index: 1,
    title: 'Production Sound',
    cat: 'production',
    body: 'Interviews, documentaries, reality television, feature films, and so much more.',
    linkLabel: 'Check out our equipment',
    linkHref: `${base}/equipment`,
  },
  {
    index: 2,
    title: 'Audio Post',
    cat: 'post',
    body: "From dialogue edits to abstract sound design, we've worked on films, video games, museum pieces, and public exhibits.",
  },
  {
    index: 3,
    title: 'Events',
    cat: 'events',
    // PLACEHOLDER COPY — Events is a newly promoted service line with no
    // real source content yet. Replace with the client's actual language
    // before launch.
    body: 'Live event mixing and on-site production audio support — panels, conferences, and corporate gatherings.',
  },
];

const defaultCat = 'production';
// Featured Work loads with everything collapsed — no row opens automatically.

const description = 'TYO Sound — production sound, audio post, and events audio engineering in Washington, D.C. and Baltimore. Interviews, documentaries, film, and live events.';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'TYO Sound',
  description,
  url: new URL(base + '/', Astro.site).toString(),
  telephone: '+1-240-608-8286',
  email: 'matt@tyosound.com',
  areaServed: [
    { '@type': 'City', name: 'Washington, D.C.' },
    { '@type': 'City', name: 'Baltimore' },
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Washington',
    addressRegion: 'DC',
    addressCountry: 'US',
  },
  // No street address was in scope for this handoff — PostalAddress is
  // deliberately locality-level only. Add streetAddress here if/when the
  // client wants a precise service address surfaced to search engines.
  sameAs: [],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEOHead title="TYO Sound — Production + Events Audio Engineering" description={description} ogImage={`${base}/img/hero-dc-capitol.png`} />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <!-- HERO -->
    <section class="hero" id="main">
      <img class="hero-photo" src={`${base}/img/hero-dc-capitol.png`} alt="Washington, D.C. streetscape near the U.S. Capitol" />
      <div class="hero-scrim"></div>
      <div class="hero-header"><NavHeader theme="onPhoto" active="Services" /></div>
      <div class="hero-content">
        <Eyebrow onLight={false} class="hero-eyebrow">Washington D.C. Based</Eyebrow>
        <h1 class="hero-title">Production + Events<br />Audio Engineering</h1>
        <div class="hero-ctas">
          <Button href="#services" variant="outline" onLight={false}>See featured work</Button>
          <Button href={`${base}/equipment`} variant="outline" onLight={false}>Equipment rental</Button>
        </div>
      </div>
    </section>

    <!-- WHAT WE DO -->
    <section class="what-we-do" id="services">
      <div class="content">
        <Eyebrow onLight={false} muted>What we do</Eyebrow>
        <div class="service-cols" data-service-cols>
          {services.map((s) => (
            <ServiceColumn
              index={s.index}
              title={s.title}
              body={s.body}
              cat={s.cat}
              selected={s.cat === defaultCat}
              linkLabel={s.linkLabel}
              linkHref={s.linkHref}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- FEATURED WORK -->
    <section class="featured-work" id="featured-work">
      <canvas class="fw-static" data-tv-static aria-hidden="true"></canvas>
      <div class="fw-burst-overlay" data-tv-burst-overlay aria-hidden="true">
        <canvas class="fw-burst-canvas" data-tv-burst></canvas>
      </div>
      <div class="content">
        <div class="fw-header">
          <h2 class="fw-title">Featured Work</h2>
          <span class="fw-cat" data-fw-cat-label>Production Sound</span>
        </div>
        <div data-fw-list>
          {projects.map((p) => (
            <FeaturedWorkItem
              id={p.id}
              title={p.title}
              client={p.client}
              role={p.role}
              cat={p.cat}
              youtubeId={p.youtubeId}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- CLIENTS -->
    <section class="clients">
      <div class="content">
        <TrustBar label="Clients Include" />
      </div>
    </section>

    <!-- RECENT POSTS -->
    <section class="recent-posts">
      <div class="content">
        <Eyebrow muted>Recent Posts</Eyebrow>
        <!--
          Self-hosted grid. The reused Elfsight embed (same widget ID the
          old Webflow site used) turned out to be domain-locked — no posts
          loaded and its badge wouldn't hide, even on the deployed domain.
          This pulls from src/data/instagram.json instead; see that file's
          _note and docs/EDITING.md for how to add a new post.
        -->
        <div class="ig-wrap" data-ig-wrap>
          <div class="ig-grid">
            {instagramData.posts.map((post, i) => (
              <a class="ig-tile" data-ig-tile data-hidden={i >= 4 ? 'true' : undefined} href={instagramData.profileUrl} target="_blank" rel="noopener">
                <img src={`${base}${post.image}`} alt={post.alt} loading="lazy" />
              </a>
            ))}
          </div>
          {instagramData.posts.length > 4 && (
            <div class="ig-more-wrap">
              <button class="ig-more-btn" data-ig-load-more>Load more</button>
            </div>
          )}
        </div>
      </div>
    </section>

    <SiteFooter />

    <script define:vars={{ services: services.map((s) => ({ cat: s.cat, title: s.title })), projects: projects.map((p) => ({ id: p.id, cat: p.cat })), defaultCat }}>
      const colsWrap = document.querySelector('[data-service-cols]');
      const listWrap = document.querySelector('[data-fw-list]');
      const catLabel = document.querySelector('[data-fw-cat-label]');
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (colsWrap && listWrap) {
        const cols = [...colsWrap.querySelectorAll('[data-service-col]')];
        const rows = [...listWrap.querySelectorAll('[data-work-item]')];

        function swapFilter(cat) {
          cols.forEach((c) => {
            const isSelected = c.dataset.cat === cat;
            c.setAttribute('data-selected', String(isSelected));
            c.querySelector('.col-select')?.setAttribute('aria-pressed', String(isSelected));
          });
          const svc = services.find((s) => s.cat === cat);
          if (catLabel && svc) catLabel.textContent = svc.title;

          rows.forEach((r) => {
            const match = r.dataset.cat === cat;
            r.setAttribute('data-hidden', String(!match));
          });

          // Featured Work always loads/switches with everything collapsed —
          // no row auto-opens on category change.
          rows.forEach((r) => setOpen(r, false));
        }

        // "Changing the channel": the row swap happens immediately, and a
        // noise burst + jitter (playChannelChange, defined below) plays
        // alongside it as a decorative accompaniment.
        function applyFilter(cat) {
          swapFilter(cat);
          if (window.playChannelChange) window.playChannelChange();
        }

        function setOpen(row, open) {
          row.setAttribute('data-open', String(open));
          const iframe = row.querySelector('iframe[data-youtube-src]');
          const btn = row.querySelector('[data-work-toggle]');
          if (btn) btn.setAttribute('aria-expanded', String(open));
          if (iframe) {
            if (open) iframe.src = iframe.dataset.youtubeSrc;
            else iframe.removeAttribute('src');
          }
        }

        cols.forEach((c) => {
          const selectBtn = c.querySelector('.col-select');
          selectBtn?.addEventListener('click', () => applyFilter(c.dataset.cat));
        });

        rows.forEach((r) => {
          const btn = r.querySelector('[data-work-toggle]');
          btn?.addEventListener('click', () => {
            const isOpen = r.dataset.open === 'true';
            rows.forEach((other) => other !== r && setOpen(other, false));
            setOpen(r, !isOpen);
            if (!isOpen) {
              // Wait for the expand transition (--dur-slow, 480ms) so the
              // scroll target accounts for the row's final expanded height.
              setTimeout(() => {
                r.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block: 'nearest' });
              }, 500);
            }
          });
        });

        // initial: mark filtered-out rows hidden (server rendered all as visible);
        // everything stays collapsed — applyFilter no longer auto-opens a row.
        rows.forEach((r) => r.setAttribute('data-hidden', String(r.dataset.cat !== defaultCat)));
      }
    </script>

    <script>
      // Recent Posts: starts at 4 tiles, "Load more" reveals 4 more per
      // click (already server-rendered, just toggling data-hidden — same
      // pattern as the Featured Work filter) until none are left hidden.
      const igWrap = document.querySelector('[data-ig-wrap]');
      if (igWrap) {
        const tiles = [...igWrap.querySelectorAll('[data-ig-tile]')];
        const moreBtn = igWrap.querySelector('[data-ig-load-more]');
        moreBtn?.addEventListener('click', () => {
          const hidden = tiles.filter((t) => t.dataset.hidden === 'true');
          hidden.slice(0, 4).forEach((t) => t.removeAttribute('data-hidden'));
          if (hidden.length <= 4) moreBtn.style.display = 'none';
        });
      }
    </script>

    <script>
      // Shared static-noise painter — draws random grayscale noise into a
      // canvas sized to its own real rendered resolution (capped at 2x
      // devicePixelRatio) every frame. Used both for the continuous
      // low-opacity background behind Featured Work and for the short
      // burst that plays on a service-filter change. No video file to
      // ship/host either way.
      function runStatic(canvas, opts) {
        opts = opts || {};
        const fps = opts.fps || 90;
        const ctx = canvas.getContext('2d');
        const scale = Math.min(window.devicePixelRatio || 1, 2);
        let w = 0, h = 0, timer = null, ro = null;
        function resize() {
          const r = canvas.getBoundingClientRect();
          w = Math.max(1, Math.round(r.width * scale));
          h = Math.max(1, Math.round(r.height * scale));
          canvas.width = w; canvas.height = h;
        }
        function draw() {
          if (!ctx || !w || !h) return;
          const frame = ctx.createImageData(w, h);
          const d = frame.data;
          for (let i = 0; i < d.length; i += 4) {
            const v = Math.random() * 255;
            d[i] = v; d[i + 1] = v; d[i + 2] = v; d[i + 3] = 255;
          }
          ctx.putImageData(frame, 0, 0);
        }
        resize(); draw();
        if (typeof ResizeObserver !== 'undefined') {
          ro = new ResizeObserver(() => { resize(); draw(); });
          ro.observe(canvas);
        }
        if (opts.playing !== false) timer = setInterval(draw, 1000 / fps);
        return function stop() { if (timer) clearInterval(timer); if (ro) ro.disconnect(); };
      }

      const reduceMotionStatic = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Continuous background static — one still frame when reduced motion
      // is preferred (playing: false skips the interval but resize()+draw()
      // still run once), otherwise a slow ~11fps loop at low opacity.
      const bgCanvas = document.querySelector('[data-tv-static]');
      if (bgCanvas instanceof HTMLCanvasElement) {
        runStatic(bgCanvas, { fps: 11, playing: !reduceMotionStatic });
      }

      // Channel-change burst: a quick real noise burst (screen-blended so
      // it lightens rather than blacks out), held flat, then wiped off
      // horizontally — rather than snapping to invisible — using one of a
      // few randomized direction/speed variants so repeated switches don't
      // feel identical. A jitter/brightness-flicker plays on the Featured
      // Work list itself throughout, independently randomized between a
      // few shake intensities (the original ±3px version is kept as the
      // most dynamic tier). Exposed on window so the filter-switch handler
      // above can call it.
      const burstCanvas = document.querySelector('[data-tv-burst]');
      const burstOverlay = document.querySelector('[data-tv-burst-overlay]');
      const fwList = document.querySelector('[data-fw-list]');
      const BURST_HOLD_DUR = 160; // flat full-static hold before the wipe-off starts
      const BURST_OVERLAY_OPACITY = 0.13;
      const WIPE_VARIANTS = [
        { name: 'right-a', duration: 200 },
        { name: 'left-a', duration: 200 },
        { name: 'right-b', duration: 280 },
        { name: 'left-b', duration: 150 },
      ];
      const SHAKE_CLASSES = ['fw-v-js-soft', 'fw-v-js-med', 'fw-v-js'];

      window.playChannelChange = function playChannelChange() {
        if (reduceMotionStatic || !(burstCanvas instanceof HTMLCanvasElement) || !burstOverlay || !fwList) return;
        const variant = WIPE_VARIANTS[Math.floor(Math.random() * WIPE_VARIANTS.length)];
        const shakeClass = SHAKE_CLASSES[Math.floor(Math.random() * SHAKE_CLASSES.length)];

        burstOverlay.removeAttribute('data-wipe');
        burstOverlay.style.opacity = '1';
        burstCanvas.style.opacity = String(BURST_OVERLAY_OPACITY);
        SHAKE_CLASSES.forEach((c) => fwList.classList.remove(c));
        void fwList.offsetWidth; // restart the animations if still mid-run
        fwList.classList.add(shakeClass);
        const stopBurst = runStatic(burstCanvas, { fps: 60, playing: true });

        setTimeout(() => {
          // Wipe-off starts: the CSS animation for this variant name
          // carries the clip-path from fully visible to fully clipped.
          burstOverlay.style.setProperty('--wipe-duration', variant.duration + 'ms');
          burstOverlay.setAttribute('data-wipe', variant.name);
        }, BURST_HOLD_DUR);

        setTimeout(() => {
          burstOverlay.style.opacity = '0';
          burstOverlay.removeAttribute('data-wipe');
          burstCanvas.style.opacity = '0';
          fwList.classList.remove(shakeClass);
          stopBurst();
        }, BURST_HOLD_DUR + variant.duration);
      };
    </script>

    <style>
      /* In-page anchor jumps (hero CTA, nav "Work" link) animate instead of
         instantly cutting to position. */
      :global(html) { scroll-behavior: smooth; }
      @media (prefers-reduced-motion: reduce) {
        :global(html) { scroll-behavior: auto; }
      }
      body {
        margin: 0;
        font-family: var(--font-sans);
        background: var(--bg-page);
        /* Tighter section rhythm than the shared --section-pad-y token —
           client feedback on the live preview: too much dead space between
           sections. */
        --section-gap-home: clamp(32px, 4vw, 64px);
      }
      .content { max-width: var(--content-max); margin: 0 auto; padding: 0 var(--page-gutter); }

      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        z-index: 100;
        background: var(--white);
        color: var(--black);
        padding: var(--space-3) var(--space-5);
        font-family: var(--font-sans);
        font-weight: var(--weight-medium);
        text-transform: uppercase;
        letter-spacing: var(--tracking-wide);
      }
      .skip-link:focus {
        left: var(--space-4);
        top: var(--space-4);
      }

      /* HERO */
      .hero { position: relative; min-height: 100vh; display: flex; flex-direction: column; overflow: hidden; }
      .hero-photo { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
      .hero-scrim { position: absolute; inset: 0; background: var(--scrim-hero); }
      .hero-header { position: relative; z-index: 2; }
      .hero-content {
        position: relative; z-index: 2; margin-top: auto;
        max-width: var(--content-max); margin-inline: auto; width: 100%;
        padding: 0 var(--page-gutter) var(--space-9);
        color: var(--white);
      }
      .hero-title {
        margin: var(--space-4) 0 var(--space-6);
        font-weight: var(--weight-bold);
        text-transform: uppercase;
        font-size: var(--text-hero);
        line-height: var(--leading-tight);
        letter-spacing: var(--tracking-tight);
        max-width: 20ch;
        text-shadow: 0 2px 12px rgba(0, 0, 0, 0.45);
      }
      /* Subtle shadow so both read clearly over the hero photo regardless
         of what's behind them. */
      :global(.hero-eyebrow) { text-shadow: 0 1px 6px rgba(0, 0, 0, 0.5); }
      .hero-ctas { display: flex; flex-wrap: wrap; gap: var(--space-4); }

      /* WHAT WE DO */
      .what-we-do { background: var(--bg-inverse); padding: var(--section-gap-home) 0; }
      .service-cols {
        margin-top: var(--space-6);
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: clamp(24px, 4vw, 56px);
      }
      /* CLIENTS */
      .clients { background: var(--bg-inverse); padding: var(--section-gap-home) 0; }

      /* FEATURED WORK */
      .featured-work { position: relative; background: var(--bg-muted); padding: var(--section-gap-home) 0; overflow: hidden; }
      .featured-work > .content { position: relative; z-index: 1; }
      /* Analog-TV static behind the section — a new stylistic addition (the
         real site has no video here, just a flat gray layer), built as a
         canvas redrawn with random noise rather than a video file, so
         there's no asset to source or host. Smooth (non-pixelated) scaling
         keeps the grain fine rather than blocky. Kept low-opacity so text
         stays legible; a static (non-animating) frame is drawn when the
         visitor prefers reduced motion. */
      .fw-static {
        position: absolute;
        inset: 0;
        z-index: 0;
        width: 100%;
        height: 100%;
        opacity: 0.06;
        pointer-events: none;
      }
      /* "Changing the channel": a real noise burst (screen-blended, so it
         lightens rather than blacks out) plus a horizontal jitter on the
         Featured Work list itself, played when the service filter changes.
         The row swap happens immediately — this is a decorative
         accompaniment, not a mask for a delayed swap. */
      .fw-burst-overlay {
        position: absolute;
        inset: 0;
        z-index: 5;
        pointer-events: none;
        overflow: hidden;
        opacity: 0;
      }
      .fw-burst-canvas {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        mix-blend-mode: screen;
      }
      /* Wipe-off, instead of the static just vanishing: clip-path sweeps
         the visible region off to the right or off to the left. Four
         variants — two directions at two different speeds each — picked
         at random per trigger (JS sets --wipe-duration and the data-wipe
         attribute). */
      .fw-burst-overlay { clip-path: inset(0 0 0 0); }
      @keyframes fw-wipe-right {
        from { clip-path: inset(0 0 0 0); }
        to   { clip-path: inset(0 0 0 100%); }
      }
      @keyframes fw-wipe-left {
        from { clip-path: inset(0 0 0 0); }
        to   { clip-path: inset(0 100% 0 0); }
      }
      .fw-burst-overlay[data-wipe='right-a'] { animation: fw-wipe-right var(--wipe-duration, 200ms) ease-out forwards; }
      .fw-burst-overlay[data-wipe='left-a']  { animation: fw-wipe-left var(--wipe-duration, 200ms) ease-out forwards; }
      .fw-burst-overlay[data-wipe='right-b'] { animation: fw-wipe-right var(--wipe-duration, 280ms) ease-in-out forwards; }
      .fw-burst-overlay[data-wipe='left-b']  { animation: fw-wipe-left var(--wipe-duration, 150ms) ease-in forwards; }
      @media (prefers-reduced-motion: reduce) {
        .fw-burst-overlay[data-wipe] { animation: none; }
      }
      /* Three shake intensities, randomly picked per trigger — fwJs (the
         original) stays the most dynamic; the other two are milder scaled-
         down versions so repeated switches don't all feel the same. */
      @keyframes fwJs {
        0%   { transform: translateX(-3px); filter: brightness(1.08); opacity: .9; }
        25%  { transform: translateX(2px); }
        50%  { transform: translateX(-1.5px); opacity: 1; }
        75%  { transform: translateX(1px); }
        100% { transform: translateX(0); filter: none; }
      }
      @keyframes fwJsMed {
        0%   { transform: translateX(-1.6px); filter: brightness(1.04); opacity: .94; }
        25%  { transform: translateX(1.1px); }
        50%  { transform: translateX(-0.8px); opacity: 1; }
        75%  { transform: translateX(0.5px); }
        100% { transform: translateX(0); filter: none; }
      }
      @keyframes fwJsSoft {
        0%   { transform: translateX(-0.75px); filter: brightness(1.015); opacity: .98; }
        50%  { transform: translateX(0.5px); }
        100% { transform: translateX(0); filter: none; }
      }
      [data-fw-list].fw-v-js {
        animation: fwJs 0.3s ease-out both;
        will-change: transform, filter;
      }
      [data-fw-list].fw-v-js-med {
        animation: fwJsMed 0.3s ease-out both;
        will-change: transform, filter;
      }
      [data-fw-list].fw-v-js-soft {
        animation: fwJsSoft 0.3s ease-out both;
        will-change: transform, filter;
      }
      @media (prefers-reduced-motion: reduce) {
        [data-fw-list].fw-v-js,
        [data-fw-list].fw-v-js-med,
        [data-fw-list].fw-v-js-soft { animation: none; }
      }
      .fw-header { display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-4); margin-bottom: var(--space-5); }
      /* Real size pulled from the live site's "home__featuredwork-header"
         style (2.85rem/-0.1rem) — this is a large display heading on the
         real site, not a small eyebrow label as first assumed. */
      .fw-title {
        margin: 0;
        font-family: var(--font-sans);
        font-weight: var(--weight-bold);
        font-size: clamp(1.75rem, 4vw, 2.85rem);
        letter-spacing: -0.1rem;
        line-height: 1;
        text-transform: uppercase;
        color: var(--text-primary);
      }
      .fw-cat { font-family: var(--font-sans); font-weight: var(--weight-medium); font-size: var(--text-sm); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--text-primary); }

      /* RECENT POSTS */
      .recent-posts { background: var(--white); padding: var(--section-gap-home) 0; }
      .ig-wrap { margin-top: var(--space-5); }
      .ig-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: clamp(4px, 1.8vw, 10px);
      }
      .ig-tile {
        display: block;
        aspect-ratio: 1 / 1;
        border: 1px solid var(--border);
        overflow: hidden;
      }
      .ig-tile img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: opacity var(--dur-base);
      }
      .ig-tile:hover img { opacity: var(--hover-opacity); }
      .ig-tile[data-hidden='true'] { display: none; }
      .ig-more-wrap { display: flex; justify-content: center; margin-top: var(--space-6); }
      .ig-more-btn {
        font-family: var(--font-sans);
        font-weight: var(--weight-medium);
        font-size: var(--text-sm);
        letter-spacing: var(--tracking-wide);
        text-transform: uppercase;
        padding: 12px 26px;
        border-radius: var(--radius-md);
        border: var(--border-rule) solid var(--black);
        background: transparent;
        color: var(--black);
        cursor: pointer;
        transition: background var(--dur-fast), color var(--dur-fast);
      }
      .ig-more-btn:hover { background: var(--black); color: var(--white); }

      @media (max-width: 760px) {
        .service-cols { grid-template-columns: 1fr; gap: var(--space-6); }
      }
    </style>
  </body>
</html>
