---
import '../styles/styles.css';
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>TYO Sound — Production + Events Audio Engineering</title>
    <meta
      name="description"
      content="TYO Sound — production sound, audio post, and events audio engineering in Washington, D.C. and Baltimore."
    />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
  </head>
  <body>
    <main class="shell">
      <div class="brand">
        <span class="waveform" aria-hidden="true">
          <i></i><i></i><i></i><i></i><i></i>
        </span>
        <span class="wordmark">TYO SOUND</span>
      </div>
      <p class="eyebrow">Washington D.C. + Baltimore</p>
      <p class="note">Site rebuild in progress — Bucket 0 pipeline live.</p>
    </main>

    <style>
      body {
        margin: 0;
        background: var(--bg-inverse);
        color: var(--text-inverse);
        font-family: var(--font-sans, 'Space Grotesk', system-ui, sans-serif);
        min-height: 100vh;
        display: grid;
        place-items: center;
      }
      .shell {
        text-align: center;
        padding: var(--page-gutter, 40px);
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 14px;
      }
      .wordmark {
        font-weight: 700;
        font-size: clamp(1.75rem, 5vw, 3rem);
        letter-spacing: 0.14em;
      }
      .waveform {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        height: 1.4em;
      }
      .waveform i {
        display: block;
        width: 3px;
        background: currentColor;
        border-radius: 1px;
      }
      .waveform i:nth-child(1) { height: 40%; }
      .waveform i:nth-child(2) { height: 75%; }
      .waveform i:nth-child(3) { height: 100%; }
      .waveform i:nth-child(4) { height: 60%; }
      .waveform i:nth-child(5) { height: 30%; }
      .eyebrow {
        margin-top: 24px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 13px;
        color: var(--gray-400);
      }
      .note {
        margin-top: 8px;
        font-weight: 400;
        font-size: 15px;
        color: var(--gray-500);
      }
    </style>
  </body>
</html>
