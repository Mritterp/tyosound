---
import '../styles/styles.css';
import NavHeader from '../components/NavHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';
import TextLink from '../components/TextLink.astro';
import ServiceColumn from '../components/ServiceColumn.astro';
import TrustBar from '../components/TrustBar.astro';
import FeaturedWorkItem from '../components/FeaturedWorkItem.astro';
import SEOHead from '../components/SEOHead.astro';
import projectsData from '../data/projects.json';

const base = import.meta.env.BASE_URL;
const projects = projectsData.projects;

const services = [
  {
    index: 1,
    title: 'Production Sound',
    cat: 'production',
    body: 'Interviews, documentaries, reality television, feature films, and so much more.',
    linkLabel: 'Check out our equipment',
    linkHref: `${base}/equipment`,
  },
  {
    index: 2,
    title: 'Audio Post',
    cat: 'post',
    body: "From dialogue edits to abstract sound design, we've worked on films, video games, museum pieces, and public exhibits.",
  },
  {
    index: 3,
    title: 'Events',
    cat: 'events',
    // PLACEHOLDER COPY — Events is a newly promoted service line with no
    // real source content yet. Replace with the client's actual language
    // before launch.
    body: 'Live event mixing and on-site production audio support — panels, conferences, and corporate gatherings.',
  },
];

const defaultCat = 'production';
// Featured Work loads with everything collapsed — no row opens automatically.

const description = 'TYO Sound — production sound, audio post, and events audio engineering in Washington, D.C. and Baltimore. Interviews, documentaries, film, and live events.';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'TYO Sound',
  description,
  url: new URL(base + '/', Astro.site).toString(),
  telephone: '+1-240-608-8286',
  email: 'matt@tyosound.com',
  areaServed: [
    { '@type': 'City', name: 'Washington, D.C.' },
    { '@type': 'City', name: 'Baltimore' },
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Washington',
    addressRegion: 'DC',
    addressCountry: 'US',
  },
  // No street address was in scope for this handoff — PostalAddress is
  // deliberately locality-level only. Add streetAddress here if/when the
  // client wants a precise service address surfaced to search engines.
  sameAs: [],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEOHead title="TYO Sound — Production + Events Audio Engineering" description={description} ogImage={`${base}/img/hero-dc-capitol.png`} />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <!-- HERO -->
    <section class="hero" id="main">
      <img class="hero-photo" src={`${base}/img/hero-dc-capitol.png`} alt="Washington, D.C. streetscape near the U.S. Capitol" />
      <div class="hero-scrim"></div>
      <div class="hero-header"><NavHeader theme="onPhoto" active="Work" /></div>
      <div class="hero-content">
        <Eyebrow onLight={false}>Washington D.C. Based</Eyebrow>
        <h1 class="hero-title">Production + Events<br />Audio Engineering</h1>
        <div class="hero-ctas">
          <Button href="#services" variant="outline" onLight={false}>See featured work</Button>
          <Button href={`${base}/equipment`} variant="outline" onLight={false}>Equipment rental</Button>
        </div>
      </div>
    </section>

    <!-- WHAT WE DO -->
    <section class="what-we-do" id="services">
      <div class="content">
        <Eyebrow onLight={false} muted>What we do</Eyebrow>
        <div class="service-cols" data-service-cols>
          {services.map((s) => (
            <ServiceColumn
              index={s.index}
              title={s.title}
              body={s.body}
              cat={s.cat}
              selected={s.cat === defaultCat}
              linkLabel={s.linkLabel}
              linkHref={s.linkHref}
            />
          ))}
        </div>
        <div class="trust-wrap">
          <TrustBar />
        </div>
      </div>
    </section>

    <!-- FEATURED WORK -->
    <section class="featured-work" id="featured-work">
      <canvas class="fw-static" data-tv-static aria-hidden="true"></canvas>
      <div class="content">
        <div class="fw-header">
          <h2 class="fw-title">Featured Work</h2>
          <span class="fw-cat" data-fw-cat-label>Production Sound</span>
        </div>
        <div data-fw-list>
          {projects.map((p) => (
            <FeaturedWorkItem
              id={p.id}
              title={p.title}
              client={p.client}
              role={p.role}
              cat={p.cat}
              youtubeId={p.youtubeId}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- RECENT POSTS -->
    <section class="recent-posts">
      <div class="content">
        <Eyebrow muted>Recent Posts</Eyebrow>
        <!--
          Real Elfsight Instagram feed widget, read directly off the live
          Webflow site's own embed (same widget ID it already uses) rather
          than a new one — reuses existing config, no new account needed.
          If it ever stops showing @Ritterpusch's posts, the source account
          is changed in the Elfsight dashboard this widget ID belongs to,
          not in this code.
        -->
        <div class="ig-wrap">
          <script src="https://apps.elfsight.com/p/platform.js" defer></script>
          <div class="elfsight-app-16dbe8d3-b603-489d-9068-3fd9ed8f416e"></div>
        </div>
      </div>
    </section>

    <SiteFooter />

    <script define:vars={{ services: services.map((s) => ({ cat: s.cat, title: s.title })), projects: projects.map((p) => ({ id: p.id, cat: p.cat })), defaultCat }}>
      const colsWrap = document.querySelector('[data-service-cols]');
      const listWrap = document.querySelector('[data-fw-list]');
      const catLabel = document.querySelector('[data-fw-cat-label]');
      if (colsWrap && listWrap) {
        const cols = [...colsWrap.querySelectorAll('[data-service-col]')];
        const rows = [...listWrap.querySelectorAll('[data-work-item]')];

        function applyFilter(cat) {
          cols.forEach((c) => {
            const isSelected = c.dataset.cat === cat;
            c.setAttribute('data-selected', String(isSelected));
            c.querySelector('.col-select')?.setAttribute('aria-pressed', String(isSelected));
          });
          const svc = services.find((s) => s.cat === cat);
          if (catLabel && svc) catLabel.textContent = svc.title;

          rows.forEach((r) => {
            const match = r.dataset.cat === cat;
            r.setAttribute('data-hidden', String(!match));
          });

          // Featured Work always loads/switches with everything collapsed —
          // no row auto-opens on category change.
          rows.forEach((r) => setOpen(r, false));
        }

        function setOpen(row, open) {
          row.setAttribute('data-open', String(open));
          const iframe = row.querySelector('iframe[data-youtube-src]');
          const btn = row.querySelector('[data-work-toggle]');
          if (btn) btn.setAttribute('aria-expanded', String(open));
          if (iframe) {
            if (open) iframe.src = iframe.dataset.youtubeSrc;
            else iframe.removeAttribute('src');
          }
        }

        cols.forEach((c) => {
          const selectBtn = c.querySelector('.col-select');
          selectBtn?.addEventListener('click', () => applyFilter(c.dataset.cat));
        });

        rows.forEach((r) => {
          const btn = r.querySelector('[data-work-toggle]');
          btn?.addEventListener('click', () => {
            const isOpen = r.dataset.open === 'true';
            rows.forEach((other) => other !== r && setOpen(other, false));
            setOpen(r, !isOpen);
          });
        });

        // initial: mark filtered-out rows hidden (server rendered all as visible);
        // everything stays collapsed — applyFilter no longer auto-opens a row.
        rows.forEach((r) => r.setAttribute('data-hidden', String(r.dataset.cat !== defaultCat)));
      }
    </script>

    <script>
      // Analog-TV static behind Featured Work: draws random grayscale noise
      // at (roughly) the canvas's real rendered resolution every frame, for
      // fine film-grain static rather than large blocky pixels — no video
      // file to ship/host.
      const staticCanvas = document.querySelector('[data-tv-static]');
      if (staticCanvas instanceof HTMLCanvasElement) {
        const ctx = staticCanvas.getContext('2d');
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        // Half the CSS pixel size keeps this fine-grained without doing a
        // full devicePixelRatio-scaled fill every frame (still visually
        // "very fine" static, just not literally 1:1 with physical pixels).
        const RESOLUTION_SCALE = 0.5;
        let w = 0;
        let h = 0;

        function resize() {
          const rect = staticCanvas.getBoundingClientRect();
          w = Math.max(1, Math.round(rect.width * RESOLUTION_SCALE));
          h = Math.max(1, Math.round(rect.height * RESOLUTION_SCALE));
          staticCanvas.width = w;
          staticCanvas.height = h;
        }

        function drawFrame() {
          if (!ctx || !w || !h) return;
          const frame = ctx.createImageData(w, h);
          for (let i = 0; i < frame.data.length; i += 4) {
            const v = Math.random() * 255;
            frame.data[i] = v;
            frame.data[i + 1] = v;
            frame.data[i + 2] = v;
            frame.data[i + 3] = 255;
          }
          ctx.putImageData(frame, 0, 0);
        }

        resize();
        drawFrame();
        window.addEventListener('resize', () => {
          resize();
          drawFrame();
        });
        if (!reduceMotion) {
          setInterval(drawFrame, 90);
        }
      }
    </script>

    <style>
      /* In-page anchor jumps (hero CTA, nav "Work" link) animate instead of
         instantly cutting to position. */
      :global(html) { scroll-behavior: smooth; }
      @media (prefers-reduced-motion: reduce) {
        :global(html) { scroll-behavior: auto; }
      }
      body {
        margin: 0;
        font-family: var(--font-sans);
        background: var(--bg-page);
        /* Tighter section rhythm than the shared --section-pad-y token —
           client feedback on the live preview: too much dead space between
           sections. */
        --section-gap-home: clamp(32px, 4vw, 64px);
      }
      .content { max-width: var(--content-max); margin: 0 auto; padding: 0 var(--page-gutter); }

      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        z-index: 100;
        background: var(--white);
        color: var(--black);
        padding: var(--space-3) var(--space-5);
        font-family: var(--font-sans);
        font-weight: var(--weight-medium);
        text-transform: uppercase;
        letter-spacing: var(--tracking-wide);
      }
      .skip-link:focus {
        left: var(--space-4);
        top: var(--space-4);
      }

      /* HERO */
      .hero { position: relative; min-height: 100vh; display: flex; flex-direction: column; overflow: hidden; }
      .hero-photo { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
      .hero-scrim { position: absolute; inset: 0; background: var(--scrim-hero); }
      .hero-header { position: relative; z-index: 2; }
      .hero-content {
        position: relative; z-index: 2; margin-top: auto;
        max-width: var(--content-max); margin-inline: auto; width: 100%;
        padding: 0 var(--page-gutter) var(--space-9);
        color: var(--white);
      }
      .hero-title {
        margin: var(--space-4) 0 var(--space-6);
        font-weight: var(--weight-bold);
        text-transform: uppercase;
        font-size: var(--text-hero);
        line-height: var(--leading-tight);
        letter-spacing: var(--tracking-tight);
        max-width: 20ch;
      }
      .hero-ctas { display: flex; flex-wrap: wrap; gap: var(--space-4); }

      /* WHAT WE DO */
      .what-we-do { background: var(--bg-inverse); padding: var(--section-gap-home) 0; }
      .service-cols {
        margin-top: var(--space-6);
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: clamp(24px, 4vw, 56px);
      }
      .trust-wrap { margin-top: var(--space-6); padding-top: var(--space-5); border-top: 1px solid var(--border-inverse); }

      /* FEATURED WORK */
      .featured-work { position: relative; background: var(--bg-muted); padding: var(--section-gap-home) 0; overflow: hidden; }
      .featured-work > .content { position: relative; z-index: 1; }
      /* Analog-TV static behind the section — a new stylistic addition (the
         real site has no video here, just a flat gray layer), built as a
         canvas redrawn with random noise rather than a video file, so
         there's no asset to source or host. Smooth (non-pixelated) scaling
         keeps the grain fine rather than blocky. Kept low-opacity so text
         stays legible; a static (non-animating) frame is drawn when the
         visitor prefers reduced motion. */
      .fw-static {
        position: absolute;
        inset: 0;
        z-index: 0;
        width: 100%;
        height: 100%;
        opacity: 0.06;
        pointer-events: none;
      }
      .fw-header { display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-4); margin-bottom: var(--space-5); }
      /* Real size pulled from the live site's "home__featuredwork-header"
         style (2.85rem/-0.1rem) — this is a large display heading on the
         real site, not a small eyebrow label as first assumed. */
      .fw-title {
        margin: 0;
        font-family: var(--font-sans);
        font-weight: var(--weight-bold);
        font-size: clamp(1.75rem, 4vw, 2.85rem);
        letter-spacing: -0.1rem;
        line-height: 1;
        text-transform: uppercase;
        color: var(--text-primary);
      }
      .fw-cat { font-family: var(--font-sans); font-weight: var(--weight-medium); font-size: var(--text-sm); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--text-primary); }

      /* RECENT POSTS */
      .recent-posts { background: var(--white); padding: var(--section-gap-home) 0; }
      .ig-wrap { margin-top: var(--space-5); }
      /* Elfsight injects its own markup at runtime (real classes read from
         the live embed via devtools), so Astro's scoped CSS can't reach it
         — these need :global() and !important to beat the widget's own
         inline styles. Adds a visible border + gutter around each tile. */
      .ig-wrap :global(.eapps-instagram-feed-posts-item) {
        border: 1px solid var(--border) !important;
      }
      .ig-wrap :global(.eapps-instagram-feed-posts-inner) {
        margin: -10px !important;
      }
      .ig-wrap :global(.eapps-instagram-feed-posts-item) {
        margin: 10px !important;
      }

      @media (max-width: 760px) {
        .service-cols { grid-template-columns: 1fr; gap: var(--space-6); }
      }
    </style>
  </body>
</html>
